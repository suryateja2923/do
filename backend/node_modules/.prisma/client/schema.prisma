datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  MANAGER
  OWNER
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RoomType {
  AC
  NON_AC
}

enum SharingType {
  SINGLE
  DOUBLE
  TRIPLE
  FOUR_SHARING
  OTHER
}

enum BedOccupancyStatus {
  VACANT
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
  MOVE_IN
  MOVE_OUT
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum InvoiceItemType {
  RENT
  SECURITY_DEPOSIT
  BOOKING_AMOUNT
  LATE_FEE
  UTILITY
  DAMAGE_CHARGE
  OTHER
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  CASH
  BANK_TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ComplaintCategory {
  PLUMBING
  ELECTRICAL
  CLEANLINESS
  INTERNET
  FURNITURE
  NOISE
  SECURITY
  OTHER
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplaintStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationType {
  BOOKING_STATUS
  PAYMENT_DUE
  PAYMENT_SUCCESS
  COMPLAINT_UPDATE
  ANNOUNCEMENT
  SYSTEM
}

enum OwnerDocumentType {
  PAN_CARD
  GSTIN
  AADHAR_CARD
  BUSINESS_LICENSE
  OTHER
}

enum TenantDocumentType {
  AADHAR_CARD
  PAN_CARD
  VOTER_ID
  PASSPORT
  DRIVING_LICENSE
  EMPLOYEE_ID
  STUDENT_ID
  OTHER
}

enum SecurityDepositStatus {
  HELD
  REFUNDED
  PARTIALLY_REFUNDED
  FORFEITED
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationQueueStatus {
  PENDING
  SENT
  FAILED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum StaffRole {
  HOUSEKEEPER
  COOK
  SECURITY_GUARD
  MAINTENANCE_TECH
  WASH_STAFF
  OTHER
}

model User {
  id         String     @id @db.Uuid
  email      String     @unique
  phone      String?
  first_name String?
  last_name  String?
  role       UserRole   @default(USER)
  status     UserStatus @default(ACTIVE)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  profile_image      ProfileImage?
  owner_profile      OwnerProfile?
  manager_profile    ManagerProfile?
  tenant_profile     TenantProfile?
  notifications      Notification[]
  complaint_comments ComplaintComment[]
  audit_logs         AuditLog[]

  // Approval relations
  approved_owners     OwnerProfile[] @relation("OwnerApprover")
  rejected_owners     OwnerProfile[] @relation("OwnerRejector")
  approved_properties Property[]     @relation("PropertyApprover")
  rejected_properties Property[]     @relation("PropertyRejector")

  // Notification, Bed transfers tracking, and Image uploads
  notification_queue       NotificationQueue[]
  bed_transfers_made       BedTransferHistory[] @relation("TransferredByUsers")
  uploaded_property_images PropertyImage[]      @relation("UploadedPropertyImages")

  // MVP additions
  announcements_created Announcement[]
  support_tickets       SupportTicket[]
  search_histories      SearchHistory[]
  activity_logs         ActivityLog[]

  @@index([role])
  @@index([status])
}

model ProfileImage {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @unique @db.Uuid
  url        String
  path       String
  mime_type  String?
  size       Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model OwnerProfile {
  id                  String             @id @default(uuid()) @db.Uuid
  user_id             String             @unique @db.Uuid
  business_name       String?
  gst_number          String?
  pan_number          String?
  verification_status VerificationStatus @default(PENDING)
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Verification Details
  approved_by           String?   @db.Uuid
  approved_at           DateTime?
  rejected_by           String?   @db.Uuid
  rejected_at           DateTime?
  rejection_reason      String?
  approval_notes        String?
  verification_attempts Int       @default(0)

  // Relations
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  approver        User?               @relation("OwnerApprover", fields: [approved_by], references: [id], onDelete: SetNull)
  rejector        User?               @relation("OwnerRejector", fields: [rejected_by], references: [id], onDelete: SetNull)
  properties      Property[]
  owner_documents OwnerDocument[]
  managers        ManagerProfile[]
  subscriptions   OwnerSubscription[]

  @@index([verification_status])
}

model OwnerDocument {
  id               String             @id @default(uuid()) @db.Uuid
  owner_profile_id String             @db.Uuid
  type             OwnerDocumentType
  url              String
  path             String
  mime_type        String?
  size             Int?
  status           VerificationStatus @default(PENDING)
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  owner_profile OwnerProfile @relation(fields: [owner_profile_id], references: [id], onDelete: Cascade)

  @@index([owner_profile_id])
}

model ManagerProfile {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @unique @db.Uuid
  owner_id   String?  @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  user               User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  owner              OwnerProfile?     @relation(fields: [owner_id], references: [id], onDelete: SetNull)
  managed_properties ManagerProperty[]
  complaints         Complaint[]       @relation("AssignedManager")

  @@index([owner_id])
}

model TenantProfile {
  id                      String   @id @default(uuid()) @db.Uuid
  user_id                 String   @unique @db.Uuid
  emergency_contact_name  String?
  emergency_contact_phone String?
  permanent_address       String?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  user              User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tenant_documents  TenantDocument[]
  bookings          Booking[]
  rental_agreements RentalAgreement[]
  invoices          Invoice[]
  payments          Payment[]
  complaints        Complaint[]
  occupancy_history OccupancyHistory[]
  bed_transfers     BedTransferHistory[]
  security_deposits SecurityDeposit[]

  // Active check-in bed mapping (1-to-1)
  bed Bed?

  // MVP additions
  reviews      Review[]
  favorites    Favorite[]
  visitor_logs VisitorLog[]

  @@index([user_id])
}

model TenantDocument {
  id                String             @id @default(uuid()) @db.Uuid
  tenant_profile_id String             @db.Uuid
  type              TenantDocumentType
  url               String
  path              String
  mime_type         String?
  size              Int?
  status            VerificationStatus @default(PENDING)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  tenant_profile TenantProfile @relation(fields: [tenant_profile_id], references: [id], onDelete: Cascade)

  @@index([tenant_profile_id])
}

model Country {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @unique
  code       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  states State[]

  @@index([name])
}

model State {
  id         String   @id @default(uuid()) @db.Uuid
  country_id String   @db.Uuid
  name       String
  code       String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  country Country @relation(fields: [country_id], references: [id], onDelete: Cascade)
  cities  City[]

  @@unique([country_id, name])
  @@index([country_id])
}

model City {
  id         String   @id @default(uuid()) @db.Uuid
  state_id   String   @db.Uuid
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  state State  @relation(fields: [state_id], references: [id], onDelete: Cascade)
  areas Area[]

  @@unique([state_id, name])
  @@index([state_id])
}

model Area {
  id         String   @id @default(uuid()) @db.Uuid
  city_id    String   @db.Uuid
  name       String
  zip_code   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  city       City       @relation(fields: [city_id], references: [id], onDelete: Cascade)
  properties Property[]

  @@unique([city_id, name])
  @@index([city_id])
}

model Amenity {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  icon        String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  properties PropertyAmenity[]

  @@index([name])
}

model PropertyAmenity {
  property_id String   @db.Uuid
  amenity_id  String   @db.Uuid
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenity_id], references: [id], onDelete: Cascade)

  @@id([property_id, amenity_id])
  @@index([amenity_id])
}

model Property {
  id         String         @id @default(uuid()) @db.Uuid
  owner_id   String         @db.Uuid
  name       String
  address    String
  zip_code   String
  latitude   Float?
  longitude  Float?
  rules      String?
  status     PropertyStatus @default(ACTIVE)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  // Deprecated plain-text fields kept for backward compatibility
  city      String?
  state     String?
  amenities String[]

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Normalized location lookup
  area_id String? @db.Uuid

  // Property Verification details
  approved_by     String?            @db.Uuid
  approved_at     DateTime?
  rejected_by     String?            @db.Uuid
  rejected_at     DateTime?
  approval_status VerificationStatus @default(PENDING)
  approval_notes  String?

  // Relations
  owner              OwnerProfile      @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  area               Area?             @relation(fields: [area_id], references: [id], onDelete: SetNull)
  approver           User?             @relation("PropertyApprover", fields: [approved_by], references: [id], onDelete: SetNull)
  rejector           User?             @relation("PropertyRejector", fields: [rejected_by], references: [id], onDelete: SetNull)
  images             PropertyImage[]
  floors             Floor[]
  managed_managers   ManagerProperty[]
  complaints         Complaint[]
  property_amenities PropertyAmenity[]
  dashboard_summary  DashboardSummary?

  // MVP additions
  announcements        Announcement[]
  reviews              Review[]
  favorites            Favorite[]
  visitor_logs         VisitorLog[]
  staff                Staff[]
  maintenance_requests MaintenanceRequest[]

  @@index([owner_id])
  @@index([area_id])
  @@index([status])
}

model PropertyImage {
  id          String   @id @default(uuid()) @db.Uuid
  property_id String   @db.Uuid
  url         String
  path        String
  mime_type   String?
  size        Int?
  is_primary  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Upgraded Fields
  display_order  Int     @default(0)
  alt_text       String?
  uploaded_by_id String? @db.Uuid
  version        Int     @default(1)

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  property    Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  uploaded_by User?    @relation("UploadedPropertyImages", fields: [uploaded_by_id], references: [id], onDelete: SetNull)

  @@index([property_id])
}

model ManagerProperty {
  manager_id  String   @db.Uuid
  property_id String   @db.Uuid
  created_at  DateTime @default(now())

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  manager  ManagerProfile @relation(fields: [manager_id], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@id([manager_id, property_id])
  @@index([property_id])
}

model Floor {
  id           String   @id @default(uuid()) @db.Uuid
  property_id  String   @db.Uuid
  name         String
  floor_number Int
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  rooms    Room[]

  @@index([property_id])
  @@index([floor_number])
}

model Room {
  id           String      @id @default(uuid()) @db.Uuid
  floor_id     String      @db.Uuid
  room_number  String
  room_type    RoomType    @default(NON_AC)
  sharing_type SharingType @default(SINGLE)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  floor      Floor       @relation(fields: [floor_id], references: [id], onDelete: Cascade)
  beds       Bed[]
  complaints Complaint[]

  // Old room transfers tracking
  old_transfers BedTransferHistory[] @relation("OldRoomTransfers")
  new_transfers BedTransferHistory[] @relation("NewRoomTransfers")

  @@index([floor_id])
  @@index([room_type])
  @@index([sharing_type])
}

model Bed {
  id               String             @id @default(uuid()) @db.Uuid
  room_id          String             @db.Uuid
  bed_number       String
  rent             Decimal            @db.Decimal(10, 2)
  security_deposit Decimal            @db.Decimal(10, 2)
  occupancy_status BedOccupancyStatus @default(VACANT)
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt

  // 1-to-1 active tenant constraint mapping (Phase 7)
  tenant_id String? @unique @db.Uuid

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  room              Room               @relation(fields: [room_id], references: [id], onDelete: Cascade)
  tenant            TenantProfile?     @relation(fields: [tenant_id], references: [id], onDelete: SetNull)
  bookings          Booking[]
  occupancy_history OccupancyHistory[]

  // Transfers tracking
  old_transfers BedTransferHistory[] @relation("OldBedTransfers")
  new_transfers BedTransferHistory[] @relation("NewBedTransfers")

  @@index([room_id])
  @@index([tenant_id])
  @@index([occupancy_status])
}

model BedTransferHistory {
  id                String   @id @default(uuid()) @db.Uuid
  tenant_id         String   @db.Uuid
  old_bed_id        String?  @db.Uuid
  old_room_id       String?  @db.Uuid
  new_bed_id        String   @db.Uuid
  new_room_id       String   @db.Uuid
  transfer_date     DateTime @default(now())
  transfer_reason   String?
  transferred_by_id String?  @db.Uuid
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  tenant         TenantProfile @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  old_bed        Bed?          @relation("OldBedTransfers", fields: [old_bed_id], references: [id], onDelete: SetNull)
  old_room       Room?         @relation("OldRoomTransfers", fields: [old_room_id], references: [id], onDelete: SetNull)
  new_bed        Bed           @relation("NewBedTransfers", fields: [new_bed_id], references: [id], onDelete: Cascade)
  new_room       Room          @relation("NewRoomTransfers", fields: [new_room_id], references: [id], onDelete: Cascade)
  transferred_by User?         @relation("TransferredByUsers", fields: [transferred_by_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([transfer_date])
}

model Booking {
  id                String        @id @default(uuid()) @db.Uuid
  tenant_id         String        @db.Uuid
  bed_id            String        @db.Uuid
  booking_date      DateTime      @default(now())
  expected_move_in  DateTime
  expected_move_out DateTime?
  actual_move_in    DateTime?
  actual_move_out   DateTime?
  booking_amount    Decimal       @db.Decimal(10, 2)
  security_deposit  Decimal       @db.Decimal(10, 2)
  rent              Decimal       @db.Decimal(10, 2)
  status            BookingStatus @default(PENDING)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  tenant            TenantProfile     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  bed               Bed               @relation(fields: [bed_id], references: [id], onDelete: Cascade)
  rental_agreement  RentalAgreement?
  invoices          Invoice[]
  security_deposits SecurityDeposit[]

  @@index([tenant_id])
  @@index([bed_id])
  @@index([status])
}

model RentalAgreement {
  id                String          @id @default(uuid()) @db.Uuid
  booking_id        String          @unique @db.Uuid
  tenant_profile_id String          @db.Uuid
  url               String
  path              String
  mime_type         String?
  size              Int?
  signed_at         DateTime?
  expires_at        DateTime?
  status            AgreementStatus @default(DRAFT)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  booking        Booking       @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  tenant_profile TenantProfile @relation(fields: [tenant_profile_id], references: [id], onDelete: Cascade)

  @@index([tenant_profile_id])
}

model SecurityDeposit {
  id         String                @id @default(uuid()) @db.Uuid
  booking_id String                @db.Uuid
  tenant_id  String                @db.Uuid
  amount     Decimal               @db.Decimal(10, 2)
  status     SecurityDepositStatus @default(HELD)
  created_at DateTime              @default(now())
  updated_at DateTime              @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  booking Booking         @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  tenant  TenantProfile   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  refunds DepositRefund[]

  @@index([booking_id])
  @@index([tenant_id])
}

model DepositRefund {
  id                  String       @id @default(uuid()) @db.Uuid
  security_deposit_id String       @db.Uuid
  refund_amount       Decimal      @db.Decimal(10, 2)
  damage_deduction    Decimal      @default(0) @db.Decimal(10, 2)
  cleaning_charges    Decimal      @default(0) @db.Decimal(10, 2)
  refund_status       RefundStatus @default(PENDING)
  refund_date         DateTime?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  security_deposit SecurityDeposit @relation(fields: [security_deposit_id], references: [id], onDelete: Cascade)

  @@index([security_deposit_id])
}

model Invoice {
  id                   String        @id @default(uuid()) @db.Uuid
  tenant_id            String        @db.Uuid
  booking_id           String        @db.Uuid
  title                String
  description          String?
  amount               Decimal       @db.Decimal(10, 2)
  due_date             DateTime
  billing_period_start DateTime?
  billing_period_end   DateTime?
  status               InvoiceStatus @default(UNPAID)
  created_at           DateTime      @default(now())
  updated_at           DateTime      @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  tenant   TenantProfile @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  booking  Booking       @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  items    InvoiceItem[]
  payments Payment[]

  @@index([tenant_id])
  @@index([booking_id])
  @@index([status])
  @@index([due_date])
}

model InvoiceItem {
  id          String          @id @default(uuid()) @db.Uuid
  invoice_id  String          @db.Uuid
  type        InvoiceItemType
  amount      Decimal         @db.Decimal(10, 2)
  description String?
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([invoice_id])
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  invoice_id     String?       @db.Uuid
  tenant_id      String        @db.Uuid
  amount         Decimal       @db.Decimal(10, 2)
  payment_method PaymentMethod
  transaction_id String?
  gateway_name   String?
  status         PaymentStatus @default(PENDING)
  payment_date   DateTime      @default(now())
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  invoice Invoice?        @relation(fields: [invoice_id], references: [id], onDelete: SetNull)
  tenant  TenantProfile   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  receipt PaymentReceipt?

  @@index([invoice_id])
  @@index([tenant_id])
  @@index([status])
  @@index([payment_date])
}

model PaymentReceipt {
  id         String   @id @default(uuid()) @db.Uuid
  payment_id String   @unique @db.Uuid
  url        String
  path       String
  mime_type  String?
  size       Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  payment Payment @relation(fields: [payment_id], references: [id], onDelete: Cascade)
}

model Complaint {
  id             String            @id @default(uuid()) @db.Uuid
  tenant_id      String            @db.Uuid
  property_id    String            @db.Uuid
  room_id        String?           @db.Uuid
  category       ComplaintCategory
  title          String
  description    String
  priority       ComplaintPriority @default(MEDIUM)
  status         ComplaintStatus   @default(OPEN)
  assigned_to_id String?           @db.Uuid
  resolved_at    DateTime?
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  // Relations
  tenant      TenantProfile      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  property    Property           @relation(fields: [property_id], references: [id], onDelete: Cascade)
  room        Room?              @relation(fields: [room_id], references: [id], onDelete: SetNull)
  assigned_to ManagerProfile?    @relation("AssignedManager", fields: [assigned_to_id], references: [id], onDelete: SetNull)
  comments    ComplaintComment[]
  images      ComplaintImage[]

  // MVP additions
  maintenance_requests MaintenanceRequest[]

  @@index([tenant_id])
  @@index([property_id])
  @@index([status])
  @@index([priority])
}

model ComplaintComment {
  id           String   @id @default(uuid()) @db.Uuid
  complaint_id String   @db.Uuid
  user_id      String   @db.Uuid
  content      String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  complaint Complaint @relation(fields: [complaint_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([complaint_id])
}

model ComplaintImage {
  id           String   @id @default(uuid()) @db.Uuid
  complaint_id String   @db.Uuid
  url          String
  path         String
  mime_type    String?
  size         Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  complaint Complaint @relation(fields: [complaint_id], references: [id], onDelete: Cascade)

  @@index([complaint_id])
}

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  user_id    String           @db.Uuid
  title      String
  body       String
  type       NotificationType
  is_read    Boolean          @default(false)
  read_at    DateTime?
  link       String?
  created_at DateTime         @default(now())

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
}

model NotificationQueue {
  id             String                  @id @default(uuid()) @db.Uuid
  user_id        String                  @db.Uuid
  title          String
  body           String
  channel        NotificationChannel
  status         NotificationQueueStatus @default(PENDING)
  retry_count    Int                     @default(0)
  failure_reason String?
  delivery_time  DateTime?
  created_at     DateTime                @default(now())
  updated_at     DateTime                @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([created_at])
}

model DashboardSummary {
  id                String   @id @default(uuid()) @db.Uuid
  property_id       String   @unique @db.Uuid
  occupied_beds     Int      @default(0)
  vacant_beds       Int      @default(0)
  monthly_revenue   Decimal  @default(0) @db.Decimal(12, 2)
  pending_rent      Decimal  @default(0) @db.Decimal(12, 2)
  total_tenants     Int      @default(0)
  average_occupancy Float    @default(0.0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@index([property_id])
}

model OccupancyHistory {
  id            String    @id @default(uuid()) @db.Uuid
  tenant_id     String    @db.Uuid
  bed_id        String    @db.Uuid
  move_in_date  DateTime
  move_out_date DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  tenant TenantProfile @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  bed    Bed           @relation(fields: [bed_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([bed_id])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String?  @db.Uuid
  action      String
  entity_name String
  entity_id   String   @db.Uuid
  old_values  Json?
  new_values  Json?
  ip_address  String?
  created_at  DateTime @default(now())

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([entity_name, entity_id])
  @@index([created_at])
}

// ==================================================
// SAAS SUBSCRIPTION & MONETIZATION MODELS (Phase 14)
// ==================================================

model SubscriptionPlan {
  id          String          @id @default(uuid()) @db.Uuid
  name        String          @unique
  description String?
  price       Decimal         @db.Decimal(10, 2)
  interval    BillingInterval @default(MONTHLY)

  // Plan limits
  max_properties Int @default(1)
  max_rooms      Int @default(10)
  max_beds       Int @default(20)
  max_managers   Int @default(1)

  // Custom features json
  features Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  subscriptions OwnerSubscription[]

  @@index([name])
}

model OwnerSubscription {
  id               String             @id @default(uuid()) @db.Uuid
  owner_profile_id String             @db.Uuid
  plan_id          String             @db.Uuid
  status           SubscriptionStatus @default(ACTIVE)
  start_date       DateTime           @default(now())
  end_date         DateTime?
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  owner_profile OwnerProfile          @relation(fields: [owner_profile_id], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan      @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  payments      SubscriptionPayment[]

  @@index([owner_profile_id])
  @@index([plan_id])
}

model SubscriptionPayment {
  id              String        @id @default(uuid()) @db.Uuid
  subscription_id String        @db.Uuid
  amount          Decimal       @db.Decimal(10, 2)
  payment_method  PaymentMethod
  transaction_id  String?
  status          PaymentStatus @default(PENDING)
  payment_date    DateTime      @default(now())
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  subscription OwnerSubscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([subscription_id])
}

