model Announcement {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  content       String
  property_id   String?  @db.Uuid // null implies global announcement
  created_by_id String   @db.Uuid
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  property   Property? @relation(fields: [property_id], references: [id], onDelete: Cascade)
  created_by User      @relation(fields: [created_by_id], references: [id], onDelete: Cascade)

  @@index([property_id])
  @@index([created_by_id])
}

model Review {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_id   String   @db.Uuid
  property_id String   @db.Uuid
  rating      Int      @default(5)
  comment     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  tenant   TenantProfile @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  property Property      @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([property_id])
}

model Favorite {
  tenant_id   String   @db.Uuid
  property_id String   @db.Uuid
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  tenant   TenantProfile @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  property Property      @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@id([tenant_id, property_id])
  @@index([property_id])
}

model VisitorLog {
  id            String    @id @default(uuid()) @db.Uuid
  tenant_id     String    @db.Uuid
  property_id   String    @db.Uuid
  visitor_name  String
  visitor_phone String?
  relationship  String?
  entry_time    DateTime
  exit_time     DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  tenant   TenantProfile @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  property Property      @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([property_id])
}

model Staff {
  id          String     @id @default(uuid()) @db.Uuid
  property_id String     @db.Uuid
  name        String
  phone       String?
  role        StaffRole  @default(HOUSEKEEPER)
  salary      Decimal?   @db.Decimal(10, 2)
  status      UserStatus @default(ACTIVE)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  property             Property             @relation(fields: [property_id], references: [id], onDelete: Cascade)
  maintenance_requests MaintenanceRequest[]

  @@index([property_id])
  @@index([role])
}

model MaintenanceRequest {
  id             String          @id @default(uuid()) @db.Uuid
  property_id    String          @db.Uuid
  staff_id       String?         @db.Uuid // technician assigned
  complaint_id   String?         @db.Uuid // optional linked complaint
  title          String
  description    String
  estimated_cost Decimal?        @db.Decimal(10, 2)
  actual_cost    Decimal?        @db.Decimal(10, 2)
  status         ComplaintStatus @default(OPEN)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  property  Property   @relation(fields: [property_id], references: [id], onDelete: Cascade)
  staff     Staff?     @relation(fields: [staff_id], references: [id], onDelete: SetNull)
  complaint Complaint? @relation(fields: [complaint_id], references: [id], onDelete: SetNull)

  @@index([property_id])
  @@index([staff_id])
  @@index([complaint_id])
}

model SupportTicket {
  id          String            @id @default(uuid()) @db.Uuid
  user_id     String            @db.Uuid
  subject     String
  description String
  priority    ComplaintPriority @default(MEDIUM)
  status      ComplaintStatus   @default(OPEN)
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt

  // Soft Delete Fields
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  deleted_by_id String?   @db.Uuid

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
}

model SearchHistory {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String?  @db.Uuid
  query      String
  filters    Json?
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String?  @db.Uuid
  action     String
  details    String?
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([created_at])
}
