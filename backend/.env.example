# HomiePG Backend Configuration Template
PORT=3000
NODE_ENV=development

# Database connection details
DATABASE_URL="postgresql://<user>:<password>@<host>:<port>/<db_name>"

# Supabase Auth and Storage Integration Keys
SUPABASE_URL="https://<your_supabase_project>.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key-string"
SUPABASE_JWT_SECRET="your-supabase-jwt-signing-secret"

# CORS Allowed Origins separated by commas
CORS_ORIGINS="*"
